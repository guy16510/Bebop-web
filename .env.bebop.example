DRONE_MODE=bebop
PORT=3000
LOG_LEVEL=info

# Flight safety remains independent from perception.
COMMAND_RATE_HZ=20
COMMAND_TIMEOUT_MS=250
MAX_COMMAND_PERCENT=35
ARM_WINDOW_MS=10000
TELEMETRY_WARNING_MS=1000
TELEMETRY_LOCKOUT_MS=3000
MINIMUM_TAKEOFF_BATTERY_PERCENT=20
CRITICAL_BATTERY_PERCENT=10
MAXIMUM_ALTITUDE_METERS=120

# Decode to an exact half-scale of the upstream 856x480 Bebop 2 calibration.
VIDEO_MJPEG_WIDTH=428
VIDEO_MJPEG_HEIGHT=240
VIDEO_MJPEG_QUALITY=5
VIDEO_START_TIMEOUT_MS=15000

# Runtime defaults. The dashboard can change and persist these without a restart.
AUTO_START_MAPPING=true
FEATURE_AUTO_CONNECT=true
FEATURE_VIDEO_ENABLED=true
FEATURE_PERCEPTION_ENABLED=true
FEATURE_SHOW_DETECTIONS=true
FEATURE_SHOW_MAP=true
RUNTIME_FEATURES_FILE=.bebop/runtime-features.json
AUTO_START_RETRY_MS=2000
AUTO_START_FRAME_TIMEOUT_MS=15000
AUTO_START_STALE_FRAME_MS=5000
AUTO_START_TRACKING_TIMEOUT_MS=30000
AUTO_START_POLL_MS=500

# Autonomous mission service. Physical flight remains locked until it is enabled
# in the dashboard and START AUTONOMOUS FLIGHT is typed for each mission.
AUTONOMY_PORT=3001
AUTONOMY_HOST=127.0.0.1
AUTONOMY_SETTINGS_FILE=.bebop/autonomy.json
NAVIGATION_MAP_FILE=.bebop/navigation-map.json
AUTONOMY_ENABLED=false
AUTONOMY_ALLOW_PHYSICAL_FLIGHT=false
AUTONOMY_REQUIRE_VIDEO=true
AUTONOMY_REQUIRE_PERCEPTION_TRACKING=true
AUTONOMY_REQUIRE_LANDING_MARKER=false
AUTONOMY_MINIMUM_BATTERY_PERCENT=45
AUTONOMY_RESERVE_BATTERY_PERCENT=25
AUTONOMY_MINIMUM_SIGNAL_RSSI=-75
AUTONOMY_TARGET_ALTITUDE_METERS=1.2
AUTONOMY_MAXIMUM_ALTITUDE_METERS=3
AUTONOMY_MAXIMUM_HORIZONTAL_DISTANCE_METERS=30
AUTONOMY_MAXIMUM_FLIGHT_SECONDS=90
AUTONOMY_TELEMETRY_TIMEOUT_MS=1500
AUTONOMY_COMMAND_PERCENT=12
AUTONOMY_PATTERN=yaw-scan
AUTONOMY_HOVER_SECONDS=10
AUTONOMY_YAW_SCAN_SECONDS=12
AUTONOMY_TAKEOFF_PAD_ID=
AUTONOMY_LANDING_PAD_ID=
AUTONOMY_NAVIGATION_TIMEOUT_SECONDS=90
AUTONOMY_LANDING_SEARCH_SECONDS=20
AUTONOMY_COMMAND_ACK_TIMEOUT_MS=750
AUTONOMY_PIPELINE_FRESHNESS_MS=2000
AUTONOMY_DETECTION_FRESHNESS_MS=1000
AUTONOMY_LANDING_RETRY_MS=500

# npm run dev checks this image and rebuilds it only when native sources change.
DEV_REBUILD_PERCEPTION=false
PERCEPTION_IMAGE=bebop-perception-sidecar:local

# Real perception sidecar.
PERCEPTION_BACKEND=external
PERCEPTION_AUTO_START=false
PERCEPTION_COMMAND=bash scripts/run-perception-sidecar.sh
PERCEPTION_VIDEO_URL=http://host.docker.internal:3000/video.mjpeg
PERCEPTION_STATE_URL=http://host.docker.internal:3000/api/state
PERCEPTION_UPDATE_HZ=10
PERCEPTION_MAX_TRAJECTORY_POINTS=900
PERCEPTION_MAX_LANDMARKS=2500

# Ships with a measured Bebop 2 family calibration so mapping can start
# immediately. Replace this path with config/perception/bebop2.yaml after
# running the unit-specific calibration utility for maximum accuracy.
PERCEPTION_CALIBRATION_FILE=config/perception/bebop2-upstream-428x240.yaml
PERCEPTION_OUTPUT_HZ=10
DETECTION_EVERY_N_FRAMES=3
YOLOX_CONFIDENCE=0.35
OBJECT_POSITION_ESTIMATE=false

# AprilTag 36h11 landing-pad detector. It is supervised separately from SLAM.
LANDING_VISION_ENABLED=true
LANDING_VISION_COMMAND=bash scripts/run-landing-vision-sidecar.sh
LANDING_VISION_VIDEO_URL=http://host.docker.internal:3000/video.mjpeg
LANDING_VISION_OUTPUT_HZ=12
LANDING_VISION_RESTART_MS=2000
LANDING_VISION_RECONNECT_MS=300
APRILTAG_EVERY_N_FRAMES=2

VIDEO_CAPTURE_DIR=captures
GST_LAUNCH_BIN=gst-launch-1.0
