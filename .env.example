DRONE_MODE=simulated
PORT=3000
COMMAND_RATE_HZ=20
COMMAND_TIMEOUT_MS=250
MAX_COMMAND_PERCENT=35
ARM_WINDOW_MS=10000
TELEMETRY_WARNING_MS=1000
TELEMETRY_LOCKOUT_MS=3000
MINIMUM_TAKEOFF_BATTERY_PERCENT=20
CRITICAL_BATTERY_PERCENT=10
MAXIMUM_ALTITUDE_METERS=120
VIDEO_CAPTURE_DIR=captures
GST_LAUNCH_BIN=gst-launch-1.0

# Simulation is the safe default. Copy .env.bebop.example to .env for the
# physical drone, calibrated ORB-SLAM3, YOLOX, and automatic mapping startup.
PERCEPTION_BACKEND=simulation
PERCEPTION_AUTO_START=true
PERCEPTION_COMMAND=
PERCEPTION_UPDATE_HZ=10
PERCEPTION_MAX_TRAJECTORY_POINTS=900
PERCEPTION_MAX_LANDMARKS=2500
PERCEPTION_VIDEO_URL=http://127.0.0.1:3000/video.mjpeg
PERCEPTION_STATE_URL=http://127.0.0.1:3000/api/state

# Automatic mapping supervisor. It is enabled by default only when
# DRONE_MODE=bebop and PERCEPTION_BACKEND=external.
AUTO_START_MAPPING=false
AUTO_START_RETRY_MS=2000
AUTO_START_FRAME_TIMEOUT_MS=15000
AUTO_START_STALE_FRAME_MS=5000
AUTO_START_POLL_MS=500

# Docker sidecar settings used by scripts/run-perception-sidecar.sh
PERCEPTION_IMAGE=bebop-perception-sidecar:local
PERCEPTION_CALIBRATION_FILE=config/perception/bebop2.yaml
PERCEPTION_OUTPUT_HZ=10
DETECTION_EVERY_N_FRAMES=3
YOLOX_CONFIDENCE=0.35
OBJECT_POSITION_ESTIMATE=false

LOG_LEVEL=info
