DRONE_MODE=simulated
PORT=3000
COMMAND_RATE_HZ=20
COMMAND_TIMEOUT_MS=250
MAX_COMMAND_PERCENT=35
ARM_WINDOW_MS=10000
TELEMETRY_WARNING_MS=1000
TELEMETRY_LOCKOUT_MS=3000
MINIMUM_TAKEOFF_BATTERY_PERCENT=20
CRITICAL_BATTERY_PERCENT=10
MAXIMUM_ALTITUDE_METERS=120
VIDEO_CAPTURE_DIR=captures
GST_LAUNCH_BIN=gst-launch-1.0

# Simulation is the safe default. Copy .env.bebop.example to .env for the
# physical drone, calibrated ORB-SLAM3, YOLOX, and automatic mapping startup.
PERCEPTION_BACKEND=simulation
PERCEPTION_AUTO_START=true
PERCEPTION_COMMAND=
PERCEPTION_UPDATE_HZ=10
PERCEPTION_MAX_TRAJECTORY_POINTS=900
PERCEPTION_MAX_LANDMARKS=2500
PERCEPTION_VIDEO_URL=http://127.0.0.1:3000/video.mjpeg
PERCEPTION_STATE_URL=http://127.0.0.1:3000/api/state

# Automatic mapping supervisor. It is enabled by default only when
# DRONE_MODE=bebop and PERCEPTION_BACKEND=external.
AUTO_START_MAPPING=false
AUTO_START_RETRY_MS=2000
AUTO_START_FRAME_TIMEOUT_MS=15000
AUTO_START_STALE_FRAME_MS=5000
AUTO_START_POLL_MS=500

# Autonomous mission service. Disabled until explicitly enabled in the dashboard.
AUTONOMY_PORT=3001
AUTONOMY_HOST=127.0.0.1
AUTONOMY_SETTINGS_FILE=.bebop/autonomy.json
NAVIGATION_MAP_FILE=.bebop/navigation-map.json
AUTONOMY_ENABLED=false
AUTONOMY_ALLOW_PHYSICAL_FLIGHT=false
AUTONOMY_REQUIRE_VIDEO=false
AUTONOMY_REQUIRE_PERCEPTION_TRACKING=true
AUTONOMY_REQUIRE_LANDING_MARKER=false
AUTONOMY_MINIMUM_BATTERY_PERCENT=45
AUTONOMY_RESERVE_BATTERY_PERCENT=25
AUTONOMY_MINIMUM_SIGNAL_RSSI=-75
AUTONOMY_TARGET_ALTITUDE_METERS=1.2
AUTONOMY_MAXIMUM_ALTITUDE_METERS=3
AUTONOMY_MAXIMUM_HORIZONTAL_DISTANCE_METERS=30
AUTONOMY_MAXIMUM_FLIGHT_SECONDS=90
AUTONOMY_TELEMETRY_TIMEOUT_MS=1500
AUTONOMY_COMMAND_PERCENT=12
AUTONOMY_PATTERN=yaw-scan
AUTONOMY_HOVER_SECONDS=10
AUTONOMY_YAW_SCAN_SECONDS=12
AUTONOMY_TAKEOFF_PAD_ID=
AUTONOMY_LANDING_PAD_ID=
AUTONOMY_NAVIGATION_TIMEOUT_SECONDS=90
AUTONOMY_LANDING_SEARCH_SECONDS=20
AUTONOMY_COMMAND_ACK_TIMEOUT_MS=750
AUTONOMY_PIPELINE_FRESHNESS_MS=2000
AUTONOMY_DETECTION_FRESHNESS_MS=1000
AUTONOMY_LANDING_RETRY_MS=500

# AprilTag detector. Simulation synthesizes the selected landing tag.
LANDING_VISION_ENABLED=false
LANDING_VISION_COMMAND=
LANDING_VISION_OUTPUT_HZ=12
APRILTAG_EVERY_N_FRAMES=2

# Docker sidecar settings used by scripts/run-perception-sidecar.sh
PERCEPTION_IMAGE=bebop-perception-sidecar:local
PERCEPTION_CALIBRATION_FILE=config/perception/bebop2.yaml
PERCEPTION_OUTPUT_HZ=10
DETECTION_EVERY_N_FRAMES=3
YOLOX_CONFIDENCE=0.35
OBJECT_POSITION_ESTIMATE=false

# Named-object recognition. This sidecar owns YOLOX detection and appearance tracking.
RECOGNITION_ENABLED=false
RECOGNITION_COMMAND=bash scripts/run-recognition-sidecar.sh
RECOGNITION_VIDEO_URL=http://host.docker.internal:3000/video.mjpeg
RECOGNITION_REGISTRY_FILE=.bebop/recognition.json
RECOGNITION_OUTPUT_HZ=10
RECOGNITION_EVERY_N_FRAMES=2
RECOGNITION_TRACK_MAX_MISSES=12
RECOGNITION_RESTART_MS=2000
RECOGNITION_RECONNECT_MS=300
RECOGNITION_STALE_MS=1500
RECOGNITION_MINIMUM_SAMPLES=3
RECOGNITION_MAXIMUM_SAMPLES=48
RECOGNITION_MINIMUM_MARGIN=0.04
YOLOX_LOW_CONFIDENCE=0.20

LOG_LEVEL=info

# Pad-transfer GPS quality gates
AUTONOMY_MINIMUM_GPS_SATELLITES=6
AUTONOMY_GPS_TIMEOUT_MS=3000
